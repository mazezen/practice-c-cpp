{
  "tasks": [
    {
      "type": "shell",
      "label": "GCC-15 编译当前文件 (C23)",
      "command": "opt/homebrew/bin/gcc-15",
      "args": [
        "-std=c23",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "使用 GCC-15 + C23 编译当前 C 文件(macOS)"
    }
  ],
  "version": "2.0.0"
}
