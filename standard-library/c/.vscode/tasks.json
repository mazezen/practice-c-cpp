{
    "tasks": [
        {
            "type": "shell",
            "label": "GCC-15 编译当前文件 (c23)",
            "command": "opt/homebrew/bin/gcc-15",
            "args": [
                "-std=c23",
                "-Wall",
                "-Wextra",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "使用 GCC-15 + C99 编译当前 C 文件(macOS)"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc-15 生成活动文件",
            "command": "/opt/homebrew/bin/gcc-15",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}