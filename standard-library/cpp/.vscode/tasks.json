{
  "tasks": [
    {
      "type": "shell",
      "label": "G++-15 编译当前文件 (C99)",
      "command": "opt/homebrew/bin/g++-15",
      "args": [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-g",
        "-isysroot",
        "$(xcrun --show-sdk-path)",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "使用 GCC-15 + C99 编译当前 C 文件(macOS)"
    }
  ],
  "version": "2.0.0"
}
